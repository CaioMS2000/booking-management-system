{
  "name": "users-management",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsup src/infrastructure/http/server.ts --format esm --dts --clean",
    "dev": "tsx --watch src/infrastructure/http/server.ts",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:watch": "vitest",
    "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@johanblumenberg/ts-mockito": "^1.0.52",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite-node": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@repo/core": "*",
    "@repo/shared": "*",
    "@repo/system-settings-manager": "*",
    "@scalar/fastify-api-reference": "^1.44.15",
    "awilix": "^12.1.1",
    "@node-rs/argon2": "^2.0.2",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^6.1.3",
    "pg": "^8.20.0",
    "swagger-themes": "^1.4.3"
  }
}
